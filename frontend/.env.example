# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Password to access the RAG Assistant UI
API_KEY=your-secret-password

# Backend URL — required for chat to work
# Contrib runs on port 8081, VONINSIGHT on 8080
SERVER_URL=http://localhost:8081

# Optional: override the Next.js proxy target (default: http://localhost:8081)
# BACKEND_URL=http://localhost:8081
